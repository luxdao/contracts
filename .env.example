# Lux DAO Contracts Environment Variables
# Copy to .env and populate from KMS: kms.hanzo.ai

# Get from KMS: kms.hanzo.ai/lux/dao/deployer-private-key
PRIVATE_KEY=<from-kms>
# Get from KMS: kms.hanzo.ai/lux/dao/rpc-url
RPC_URL=<from-kms>
# Get from KMS: kms.hanzo.ai/lux/dao/etherscan-api-key
ETHERSCAN_API_KEY=<from-kms>
